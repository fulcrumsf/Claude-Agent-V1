\f2 \cf3 \cb4 \strokec3 Dockerfile
\f0 \cf0 \cb1 \strokec2 ,\'a0
\f2 \cf3 \cb4 \strokec3 docker-compose.yml
\f0 \cf0 \cb1 \strokec2 ,\'a0
